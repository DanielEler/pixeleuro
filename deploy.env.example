# ════════════════════════════════════════════════════════════════════
#  PixelEuro – Produktions-Deploy-Werte (Vorlage)
#  Kopiere zu "deploy.env", trage echte Werte ein. deploy.env ist gitignored.
#  Wird vom Deploy-Skript als .env auf den Server gelegt (docker compose).
# ════════════════════════════════════════════════════════════════════

# --- Server ---
PORT=3000
# Öffentliche URL (Domain hinter Caddy). Muss zur Caddyfile-Domain passen.
PUBLIC_URL=https://pixeleuro.de

# --- Datenbank (eigener Sidecar-Container) ---
# Passwort der PixelEuro-Postgres-Rolle. Lang & zufällig.
PIXEL_DB_PASSWORD=CHANGE_ME_LANG_UND_ZUFAELLIG

# --- Caddy-Netz von Semesto (extern). Wird i.d.R. automatisch erkannt. ---
EDGE_NETWORK=semesto_default

# --- Raster / Preis ---
GRID_W=500
GRID_H=250
PIXEL_PRICE_CENTS=100
MIN_ORDER_CENTS=1000
RESERVATION_MINUTES=15

# --- Stripe (optional – ohne Keys läuft die Seite, Zahlung ist nur deaktiviert) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Admin / Moderation (/admin) ---
ADMIN_TOKEN=CHANGE_ME_LANGES_ZUFAELLIGES_TOKEN

# --- Branding ---
SITE_NAME=PixelEuro
SITE_TAGLINE=1 Pixel. 1 Euro. Für die Ewigkeit im Netz.
