# ============================================================
#  Pixelwebsite – Konfiguration
#  Kopiere diese Datei zu ".env" und trage deine echten Werte ein.
#  Die .env NIEMALS ins Git committen (steht schon in .gitignore).
# ============================================================

# --- Server ---
PORT=3000
# Öffentliche Basis-URL deiner Seite (für Stripe Redirects). In Produktion deine Domain:
PUBLIC_URL=http://localhost:3000

# --- Datenbank (PostgreSQL auf Hetzner) ---
# Format: postgres://USER:PASSWORT@HOST:PORT/DATENBANK
DATABASE_URL=postgres://pixel:pixel@localhost:5432/pixelwebsite

# --- Raster / Preis ---
GRID_W=500
GRID_H=250
# Preis pro Pixel in Cent (100 = 1,00 €)
PIXEL_PRICE_CENTS=100
# Mindestbestellwert in Cent (1000 = 10,00 €) – schützt vor zu hohen Gebührenanteilen
MIN_ORDER_CENTS=1000
# Reservierungsdauer in Minuten, bevor unbezahlte Auswahl wieder freigegeben wird
RESERVATION_MINUTES=15

# --- Stripe (Zahlungsanbieter) ---
# Aus dem Stripe Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
# Signing Secret deines Webhook-Endpunkts: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Admin / Moderation ---
# Geheimes Token, um die Moderations-Oberfläche (/admin) zu schützen. Lang & zufällig wählen!
ADMIN_TOKEN=bitte-langes-zufaelliges-token-eintragen

# --- Branding (erscheint auf der Seite) ---
SITE_NAME=PixelEuro
SITE_TAGLINE=1 Pixel. 1 Euro. Für die Ewigkeit im Netz.
